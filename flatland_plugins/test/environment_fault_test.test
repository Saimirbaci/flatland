<!--
Test launchfile for environment_fault_test

Runs rosmaster so the FaultInjector can advertise the reserved ground-truth
topic, spawn obstacles, and the laser/diff_drive plugins can publish their
in-band topics, which the test subscribes to and asserts over.
-->
<launch>
  <param name="use_sim_time" value="true"/>
  <test pkg="flatland_plugins" type="environment_fault_test"
        test-name="environment_fault_test" time-limit="120.0"/>
</launch>
