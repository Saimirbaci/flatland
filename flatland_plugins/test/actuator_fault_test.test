<!--
Test launchfile for actuator_fault_test

Runs rosmaster so the FaultInjector can advertise the reserved ground-truth
topic and the diff_drive plugin can publish its in-band odom topics, which the
test subscribes to and asserts over.
-->
<launch>
  <param name="use_sim_time" value="true"/>
  <test pkg="flatland_plugins" type="actuator_fault_test"
        test-name="actuator_fault_test" time-limit="120.0"/>
</launch>
