<!--
Test launchfile for localization_fault_test

Runs rosmaster so the FaultInjector can advertise the reserved ground-truth
topic and the LocalizationFault plugin can publish amcl_pose + the map->odom tf,
which the test subscribes to and asserts over.
-->
<launch>
  <param name="use_sim_time" value="true"/>
  <test pkg="flatland_plugins" type="localization_fault_test"
        test-name="localization_fault_test" time-limit="120.0"/>
</launch>
