<!--
Test launchfile for diff_drive_actuator_test

Runs a rosmaster so the DiffDrive plugin's publish/subscribe path is live while
the actuator-dynamics (latency / deadband / torque-cap) behaviour is asserted.
-->
<launch>
  <test pkg="flatland_plugins" type="diff_drive_actuator_test"
        test-name="diff_drive_actuator_test"/>
</launch>
